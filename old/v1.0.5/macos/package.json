{
  "name": "yaja-2600-animator-macos",
  "productName": "YAJA 2600 Animator",
  "version": "1.0.5",
  "description": "macOS desktop build of YAJA 2600 Animator.",
  "main": "electron-main.js",
  "private": true,
  "author": "Nebulords",
  "license": "MIT",
  "scripts": {
    "desktop:start": "electron .",
    "desktop:portable": "electron-builder --mac zip"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nebulords.yaja2600animator",
    "productName": "YAJA 2600 Animator",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "index.css",
      "app.bundle.js",
      "assets/**/*",
      "src/**/*",
      "README.md",
      "DOCUMENTATION.md",
      "electron-main.js",
      "electron-preload.js"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.png"
    }
  }
}
